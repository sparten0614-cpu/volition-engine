{
  "name": "volition-engine",
  "version": "0.1.0",
  "description": "From tasks to desires. A motivation engine for AI agents.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "volition-demo": "./dist/demo.js"
  },
  "files": [
    "dist",
    "config",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "demo": "npx tsx src/demo.ts",
    "start": "node dist/index.js",
    "test": "npx tsx --test src/test/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "agent",
    "motivation",
    "desire",
    "autonomous",
    "neuroscience",
    "openclaw",
    "volition",
    "drive",
    "proactive"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sparten0614-cpu/volition-engine"
  },
  "homepage": "https://github.com/sparten0614-cpu/volition-engine#readme",
  "bugs": {
    "url": "https://github.com/sparten0614-cpu/volition-engine/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
